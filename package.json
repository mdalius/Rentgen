{
  "name": "rentgen",
  "productName": "Rentgen",
  "version": "1.21.0",
  "description": "Automation before automation. Finding API bugs when you have no tests.",
  "main": ".webpack/main",
  "bin": {
    "rentgen": "./dist/cli/index.js"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "check:i18n": "tsx scripts/check-i18n.ts",
    "build:cli": "tsup cli/index.ts --format cjs --target node22 --out-dir dist/cli",
    "build:cli:bin": "node scripts/build-cli-bin.cjs",
    "build:cli:bundle": "tsup --config cli/tsup.bundle.config.ts",
    "dev:cli": "tsx cli/index.ts",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-push": "npm run lint && npm run check:i18n"
  },
  "keywords": [],
  "author": {
    "name": "Liudas Jankauskas",
    "email": "liudasjan@gmail.com"
  },
  "license": "RSAL-1.0",
  "engines": {
    "node": ">=22.12"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@svgr/webpack": "^8.1.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "@yao-pkg/pkg": "^6.10.0",
    "baseline-browser-mapping": "^2.10.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "css-loader": "^7.1.2",
    "electron": "40.6.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.5.0",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "node-loader": "^2.1.0",
    "postcss-loader": "^8.2.0",
    "simple-git-hooks": "^2.13.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@inquirer/prompts": "^8.4.2",
    "@monaco-editor/react": "^4.7.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/postcss": "^4.2.0",
    "axios": "^1.13.5",
    "classnames": "^2.5.1",
    "deepmerge": "^4.3.1",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "i18next": "^26.0.3",
    "monaco-editor": "^0.55.1",
    "parse-curl": "^0.2.6",
    "postcss": "^8.5.6",
    "protobufjs": "^8.0.1",
    "react": "^19.2.4",
    "react-data-table-component": "^7.7.1",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "react-redux": "^9.2.0",
    "react-select": "^5.10.2",
    "react-tabs": "^6.1.0",
    "react-textarea-autosize": "^8.5.9",
    "reflect-metadata": "^0.2.2",
    "styled-components": "^6.3.11",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "uuid": "^13.0.2"
  }
}
